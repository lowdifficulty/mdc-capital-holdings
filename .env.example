# Auth (required for dashboard + intelligence)
SESSION_SECRET=generate-a-long-random-string
ADMIN_EMAIL=1
ADMIN_PASSWORD=1

# Sentiment data sources (optional but recommended)
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=
NEWS_API_KEY=

# Alpaca market data (optional — Yahoo Finance used as fallback)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://data.alpaca.markets
ALPACA_DATA_FEED=iex

# Database (optional — file store used in Phase 1)
DATABASE_URL=

# App URL (production)
NEXT_PUBLIC_APP_URL=https://mdccapitalholdings.com

# Optional: LLM for enhanced explanations (template explanations used by default)
OPENAI_API_KEY=
