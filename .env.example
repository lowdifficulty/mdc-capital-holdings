# Auth (required for dashboard + intelligence)
SESSION_SECRET=generate-a-long-random-string
ADMIN_EMAIL=1
ADMIN_PASSWORD=1

# Sentiment data sources (optional but recommended)
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=
NEWS_API_KEY=
QUIVER_API_KEY=
QUIVER_API_TOKEN=

# Quiver analysis engine
DEFAULT_LOOKBACK_DAYS=90
ANALYSIS_REFRESH_INTERVAL_HOURS=12

# Alpaca market data (optional — Yahoo Finance used as fallback)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://data.alpaca.markets
ALPACA_DATA_FEED=iex

# Database (optional — wellness sync uses Postgres when set)
DATABASE_URL=

# Vercel Blob (optional — wellness sync uses Blob on Vercel when DATABASE_URL is unset)
# Create a Blob store in the Vercel project Storage tab; BLOB_READ_WRITE_TOKEN is added automatically.
BLOB_READ_WRITE_TOKEN=

# App URL (production)
NEXT_PUBLIC_APP_URL=https://mdccapitalholdings.com

# Alfred voice assistant (Operations Dashboard) — required for /dashboard voice
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
# British butler voice (defaults to James — Professional British Male)
ELEVENLABS_VOICE_ID_ALFRED=
# OPENAI_REALTIME_MODEL=gpt-realtime-1.5

# Do NOT run `vercel env pull` into .env.local unless you re-add keys above afterward.
# To copy voice keys from Jude demo: powershell -File scripts/import-voice-env.ps1
